etl_warehouse/
│
├── config/                         # تنظیمات مرکزی و امنیت
│   ├── settings.yaml               # پیکربندی اصلی (محیط‌های اجرا، حجم چانک‌ها)
│   ├── databases.yaml              # اطلاعات اتصالات دیتابیس (خوانده شده از Env)
│   ├── schemas/                    # گیت‌کیپر و نگهبان ساختار جداول (Data Contract)
│   │   ├── sales_schema.json
│   │   ├── inventory_schema.json
│   │   └── reports_schema.json
│   └── mappings/                   # نگاشت فیلدهای دیتابیس مادر به انبار داده
│       ├── source_to_dw.yaml       # نقشه‌راه تبدیل نام ستون‌های قدیمی به جدید
│       └── jalali_mapping.yaml     # قواعد نگاشت زمانی
│
├── core/                           # هسته پردازشی فریم‌ورک
│   ├── engine/
│   │   ├── base_etl.py             # مدیریت تراکنش‌ها و ارث‌بری‌های کلان
│   │   ├── extractor.py            # استخراج با متد Chunking و مدیریت جنراتورها
│   │   ├── transformer.py          # موتور اعمال بیزینس‌لوجیک پخش (تخفیفات، سود، مالیات)
│   │   └── loader.py               # بارگذار فوق‌سریع با متد COPY پُست‌گرس
│   ├── utils/
│   │   ├── jalali.py               # مبدل تاریخ میلادی به شمسی و ساخت دایمنشن زمان
│   │   ├── logging.py              # لاگر پیشرفته استاندارد (تفکیک بر اساس روز)
│   │   ├── monitoring.py           # ثبت متادیتای پایپ‌لاین (تعداد ردیف، زمان اجرا) در دیتابیس
│   │   └── alerting.py             # سیستم هشدار آنی (اتصال به تلگرام/پیامک برای خطاهای بحرانی)
│   └── decorators.py               # دکوریتورهای مدیریت خطا (Retry) و محاسبه زمان اجرا
│
├── sources/                        # لایه کانکتورها (مستقل از هسته اصلی)
│   ├── base_source.py              # اینترفیس منابع داده
│   ├── mssql_source.py             # کانکتور ویژه SQL Server دیتابیس مادر (اصلاح‌شده از Postgres)
│   ├── mysql_source.py             # کانکتور فرعی (برای سیستم‌های جانبی مثل وب‌سایت فاکتوردهی)
│   ├── csv_source.py               # مدیریت لود داده‌های دستی/اکسل (تارگت‌های فروش، بودجه‌بندی)
│   └── api_source.py               # کانکتور متصل به وب‌سرویس‌های لجستیک یا سامانه تیتک (TTAC)
│
├── pipelines/                      # سناریوها و منطق پایپ‌لاین‌ها (Business Logic)
│   ├── extract_tables/             # لایه اول: انتقال داده‌های خام به جداول لندینگ (Staging)
│   │   ├── extract_customers.py
│   │   ├── extract_products.py
│   │   ├── extract_orders.py       # اقلام فاکتور فروش (تراکنش‌های ۳۰ دقیقه‌ای)
│   │   └── extract_inventory.py    # موجودی لحظه‌ای انبارها
│   │
│   ├── daily_reports/              # لایه دوم: جداول تجمیعی روزانه (Aggregated) برای افزایش سرعت متابیس
│   │   ├── daily_inventory.py      # وضعیت موجودی، اقلام رو به اتمام و تاریخ انقضا
│   │   ├── daily_sales.py          # خالص فروش ریالی روز، سود روزانه و درصد تحقق تارگت
│   │   └── daily_summary.py        # گزارش لول مدیریتی نهایی
│   │
│   ├── monthly_reports/            # گزارش‌های تجمیعی ماهانه (گزارش‌های فصلی و سهمیه‌های دارویی)
│   │   ├── monthly_sales.py
│   │   └── monthly_inventory.py
│   │
│   ├── yearly_reports/             # گزارش‌های سالانه و کلان (تحلیل روند ۱۰ سال گذشته)
│   │   ├── yearly_sales_summary.py
│   │   └── yearly_comparison.py
│   │
│   └── warehouse_analysis/         # تحلیل‌های تخصصی لوکیشن و توزیع
│       ├── inventory_by_warehouse.py
│       └── sales_by_warehouse.py
│
├── warehouse_tables/               # ساختار سازه‌ای انبار داده (PostgreSQL DDL)
│   ├── create_tables.sql           # ساختار جداول فکت و دایمنشن (Star Schema)
│   ├── migrations/                 # مدیریت تغییرات دیتابیس در طول زمان (Version Control)
│   └── indexes.sql                 # ایندکس‌های ستونی و ایندکس‌های همزمان (CONCURRENTLY)
│
├── dags/                           # زمان‌بند و ناظر فرآیندها (Airflow)
│   ├── extract_dag.py              # ارکستراتور اصلی (اجرای ۳۰ دقیقه یک‌بار تسک‌های افزایشی)
│   ├── daily_dag.py                # اجرای شبانه (رأس ساعت ۰۰:۰۵ برای ساخت لایه گزارش‌های روزانه)
│   └── monthly_dag.py              # اجرای ماهانه (اول هر ماه خورشیدی)
│
├── tests/                          # لایه تضمین کیفیت داده (Data Quality)
│   ├── test_extract.py             # صحت ارتباط با منابع داده
│   ├── test_transform.py           # تست درستی محاسبات ریالی و تخفیف‌ها
│   └── test_jalali.py              # تست عدم تداخل کبیسه‌ها در تاریخ شمسی
│
├── scripts/                        # ابزارهای اتاق بحران و عملیات دستی
│   ├── backfill.py                 # موتور بارگذاری اولیه دیتای تاریخی (۱۰۰ گیگابایت) به صورت پارتیشن شده
│   ├── validate_data.py            # چک کردن همخوانی فاکتورهای انبار داده با سیستم مادر (عدم مغایرت)
│   └── cleanup.py                  # پاک‌سازی خودکار لاگ‌های قدیمی و نگهداری دوره‌ای دیتابیس
│
├── data/                           # بافر موقت داده‌ها (دسترسی محدود و مدیریت شده در حافظه)
│   ├── raw/                        
│   ├── processed/                  
│   └── archive/                    
│
├── logs/                           # تاریخچه عملیات سیستم
│   ├── etl/                        # لاگ پایپ‌لاین‌ها
│   ├── airflow/                    # لاگ تسک‌های ایرفلو
│   └── errors/                     # خطاهای متوقف‌کننده
│
├── requirements.txt                # پکیج‌ها (SQLAlchemy, pyodbc, psycopg2, jdatetime, pydantic)
├── README.md                       # مستندات راه‌اندازی و راه‌نمای دیکشنری داده
└── .gitignore                      # جلوگیری از پوش شدن فایل‌های config حاوی پسورد به گیت